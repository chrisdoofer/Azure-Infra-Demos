graph TB
    subgraph "Resource Group Scope"
        subgraph "Monitoring & Observability"
            LAW[Log Analytics Workspace<br/>90-day retention<br/>5GB daily cap]
            AI[Action Group<br/>Email alerts]
            DIAG[Activity Log<br/>Diagnostic Settings]
        end
        
        subgraph "Governance & Automation"
            AA[Automation Account<br/>Basic SKU<br/>System Managed Identity]
            BUDGET[Budget Alert<br/>$1000/month<br/>80% & 100% thresholds]
        end
        
        subgraph "Security & Compliance"
            KV[Key Vault<br/>RBAC auth<br/>Soft delete enabled<br/>Purge protection]
            ST[Storage Account<br/>Standard LRS<br/>HTTPS only, TLS 1.2<br/>Audit logs]
        end
        
        subgraph "Business Continuity"
            RSV[Recovery Services Vault<br/>Standard tier<br/>System Managed Identity]
        end
        
        subgraph "Network Infrastructure"
            NW[Network Watcher<br/>Auto-created]
        end
    end
    
    LAW -->|Linked service| AA
    LAW -->|Receives logs| KV
    LAW -->|Receives logs| ST
    LAW -->|Receives logs| RSV
    LAW -->|Activity log| DIAG
    AI -->|Sends email| BUDGET
    
    classDef monitoring fill:#FFB900,stroke:#000,stroke-width:2px,color:#000
    classDef security fill:#FF5733,stroke:#000,stroke-width:2px,color:#fff
    classDef governance fill:#0078D4,stroke:#000,stroke-width:2px,color:#fff
    classDef backup fill:#50E6FF,stroke:#000,stroke-width:2px,color:#000
    classDef network fill:#107C10,stroke:#000,stroke-width:2px,color:#fff
    
    class LAW,AI,DIAG monitoring
    class KV,ST security
    class AA,BUDGET governance
    class RSV backup
    class NW network
