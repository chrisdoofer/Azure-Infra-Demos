graph TB
    Internet[Internet] -->|HTTPS/HTTP| AppGwPIP
    
    subgraph "Zero Trust Network - 10.0.0.0/16"
        subgraph "AppGatewaySubnet - 10.0.1.0/24"
            AppGwPIP[Public IP<br/>Standard SKU]
            AGW[Application Gateway<br/>WAF_v2 Tier<br/>OWASP 3.2 Prevention]
        end
        
        subgraph "AzureFirewallSubnet - 10.0.2.0/24"
            FWPIP[Firewall Public IP]
            FW[Azure Firewall<br/>Standard Tier<br/>Network + App Rules]
        end
        
        subgraph "AppIntegrationSubnet - 10.0.3.0/24 + NSG + Route Table"
            WEBAPP[Web App<br/>B1 Linux, Node.js 20<br/>VNet Integration]
        end
        
        subgraph "PrivateEndpointSubnet - 10.0.4.0/24 + NSG"
            PE[Private Endpoint<br/>Web App Connection]
        end
    end
    
    subgraph "PaaS Services"
        ASP[App Service Plan<br/>B1 Basic Linux]
        PDNS[Private DNS Zone<br/>privatelink.azurewebsites.net]
    end
    
    AppGwPIP --> AGW
    AGW -->|Backend Pool| WEBAPP
    WEBAPP -->|Private Link| PE
    WEBAPP -->|Hosted On| ASP
    PE -.->|DNS Resolution| PDNS
    WEBAPP -->|All Traffic| FW
    FW -->|Filtered Egress| Internet
    
    classDef security fill:#E81123,stroke:#000,stroke-width:3px,color:#fff
    classDef network fill:#50E6FF,stroke:#000,stroke-width:2px,color:#000
    classDef app fill:#0078D4,stroke:#000,stroke-width:2px,color:#fff
    classDef paas fill:#FFB900,stroke:#000,stroke-width:2px,color:#000
    classDef external fill:#107C10,stroke:#000,stroke-width:2px,color:#fff
    
    class AGW,FW security
    class WEBAPP,PE,AppGwPIP,FWPIP network
    class ASP,PDNS paas
    class Internet external
