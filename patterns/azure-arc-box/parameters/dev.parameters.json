    "deploySqlVM": {
      "value": true
    },
    "vmSize": {
      "value": "Standard_B2ms"
    },
    "vnetAddressPrefix": {
      "value": "10.0.0.0/16"
    },
    "subnetAddressPrefix": {
      "value": "10.0.1.0/24"
    }
  }
