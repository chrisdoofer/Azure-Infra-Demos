{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "location": {
      "value": "australiaeast"
    },
    "prefix": {
      "value": "arcbox"
    },
    "tags": {
      "value": {
        "owner": "dev-team",
        "workload": "azure-arc-box",
        "environment": "dev",
        "ttlHours": "48"
      }
    },
    "adminUsername": {
      "value": "arcadmin"
