{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "_generator": {
      "name": "bicep",
      "version": "0.24.24.22086",
      "templateHash": "1234567890123456789"
    }
  },
  "parameters": {
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": {
        "description": "Azure region for all resources"
      }
    },
    "prefix": {
      "type": "string",
      "defaultValue": "demo",
      "metadata": {
        "description": "Prefix for resource names"
      }
    },
    "tags": {
      "type": "object",
      "defaultValue": {
        "owner": "demo-user",
        "workload": "hub-spoke-network",
        "environment": "dev",
        "ttlHours": "24"
      },
      "metadata": {
        "description": "Tags to apply to all resources"
      }
    },
    "deployFirewall": {
      "type": "bool",
      "defaultValue": true,
      "metadata": {
        "description": "Deploy Azure Firewall in the hub"
      }
    },
    "deployVpnGateway": {
      "type": "bool",
      "defaultValue": false,
      "metadata": {
        "description": "Deploy VPN Gateway in the hub"
      }
    },
    "hubAddressPrefix": {
      "type": "string",
      "defaultValue": "10.0.0.0/16",
      "metadata": {
        "description": "Hub VNet address prefix"
      }
    },
    "spoke1AddressPrefix": {
      "type": "string",
      "defaultValue": "10.1.0.0/16",
      "metadata": {
        "description": "Spoke 1 VNet address prefix"
      }
    },
    "spoke2AddressPrefix": {
      "type": "string",
      "defaultValue": "10.2.0.0/16",
      "metadata": {
        "description": "Spoke 2 VNet address prefix"
      }
    }
  },
  "variables": {
    "hubVnetName": "[format('{0}-hub-vnet', parameters('prefix'))]",
    "spoke1VnetName": "[format('{0}-spoke1-vnet', parameters('prefix'))]",
    "spoke2VnetName": "[format('{0}-spoke2-vnet', parameters('prefix'))]",
    "hubMgmtNsgName": "[format('{0}-hub-mgmt-nsg', parameters('prefix'))]",
    "spoke1NsgName": "[format('{0}-spoke1-nsg', parameters('prefix'))]",
    "spoke2NsgName": "[format('{0}-spoke2-nsg', parameters('prefix'))]",
    "spoke1RouteTableName": "[format('{0}-spoke1-rt', parameters('prefix'))]",
    "spoke2RouteTableName": "[format('{0}-spoke2-rt', parameters('prefix'))]",
    "firewallPublicIpName": "[format('{0}-fw-pip', parameters('prefix'))]",
    "firewallName": "[format('{0}-hub-fw', parameters('prefix'))]",
    "vpnGatewayPublicIpName": "[format('{0}-vpngw-pip', parameters('prefix'))]",
    "vpnGatewayName": "[format('{0}-hub-vpngw', parameters('prefix'))]"
  },
  "resources": [
    {
      "type": "Microsoft.Network/networkSecurityGroups",
      "apiVersion": "2023-05-01",
      "name": "[variables('hubMgmtNsgName')]",
      "location": "[parameters('location')]",
      "tags": "[parameters('tags')]",
      "properties": {
        "securityRules": [
          {
            "name": "AllowVnetInbound",
            "properties": {
              "protocol": "*",
              "sourcePortRange": "*",
              "destinationPortRange": "*",
              "sourceAddressPrefix": "VirtualNetwork",
              "destinationAddressPrefix": "VirtualNetwork",
              "access": "Allow",
              "priority": 100,
              "direction": "Inbound"
            }
          },
          {
            "name": "DenyAllInbound",
            "properties": {
              "protocol": "*",
              "sourcePortRange": "*",
              "destinationPortRange": "*",
              "sourceAddressPrefix": "*",
              "destinationAddressPrefix": "*",
              "access": "Deny",
              "priority": 4096,
              "direction": "Inbound"
            }
          }
        ]
      }
    },
    {
      "type": "Microsoft.Network/networkSecurityGroups",
      "apiVersion": "2023-05-01",
      "name": "[variables('spoke1NsgName')]",
      "location": "[parameters('location')]",
      "tags": "[parameters('tags')]",
      "properties": {
        "securityRules": [
          {
            "name": "AllowVnetInbound",
            "properties": {
              "protocol": "*",
              "sourcePortRange": "*",
              "destinationPortRange": "*",
              "sourceAddressPrefix": "VirtualNetwork",
              "destinationAddressPrefix": "VirtualNetwork",
              "access": "Allow",
              "priority": 100,
              "direction": "Inbound"
            }
          },
          {
            "name": "DenyAllInbound",
            "properties": {
              "protocol": "*",
              "sourcePortRange": "*",
              "destinationPortRange": "*",
              "sourceAddressPrefix": "*",
              "destinationAddressPrefix": "*",
              "access": "Deny",
              "priority": 4096,
              "direction": "Inbound"
            }
          }
        ]
      }
    },
    {
      "type": "Microsoft.Network/networkSecurityGroups",
      "apiVersion": "2023-05-01",
      "name": "[variables('spoke2NsgName')]",
      "location": "[parameters('location')]",
      "tags": "[parameters('tags')]",
      "properties": {
        "securityRules": [
          {
            "name": "AllowVnetInbound",
            "properties": {
              "protocol": "*",
              "sourcePortRange": "*",
              "destinationPortRange": "*",
              "sourceAddressPrefix": "VirtualNetwork",
              "destinationAddressPrefix": "VirtualNetwork",
              "access": "Allow",
              "priority": 100,
              "direction": "Inbound"
            }
          },
          {
            "name": "DenyAllInbound",
            "properties": {
              "protocol": "*",
              "sourcePortRange": "*",
              "destinationPortRange": "*",
              "sourceAddressPrefix": "*",
              "destinationAddressPrefix": "*",
              "access": "Deny",
              "priority": 4096,
              "direction": "Inbound"
            }
          }
        ]
      }
    },
    {
      "condition": "[parameters('deployFirewall')]",
      "type": "Microsoft.Network/publicIPAddresses",
      "apiVersion": "2023-05-01",
      "name": "[variables('firewallPublicIpName')]",
      "location": "[parameters('location')]",
      "tags": "[parameters('tags')]",
      "sku": {
        "name": "Standard"
      },
      "properties": {
        "publicIPAllocationMethod": "Static",
        "publicIPAddressVersion": "IPv4"
      }
    },
    {
      "condition": "[parameters('deployVpnGateway')]",
      "type": "Microsoft.Network/publicIPAddresses",
      "apiVersion": "2023-05-01",
      "name": "[variables('vpnGatewayPublicIpName')]",
      "location": "[parameters('location')]",
      "tags": "[parameters('tags')]",
      "sku": {
        "name": "Standard"
      },
      "properties": {
        "publicIPAllocationMethod": "Static",
        "publicIPAddressVersion": "IPv4"
      }
    },
    {
      "type": "Microsoft.Network/virtualNetworks",
      "apiVersion": "2023-05-01",
      "name": "[variables('hubVnetName')]",
      "location": "[parameters('location')]",
      "tags": "[parameters('tags')]",
      "dependsOn": [
        "[resourceId('Microsoft.Network/networkSecurityGroups', variables('hubMgmtNsgName'))]"
      ],
      "properties": {
        "addressSpace": {
          "addressPrefixes": [
            "[parameters('hubAddressPrefix')]"
          ]
        },
        "subnets": [
          {
            "name": "AzureFirewallSubnet",
            "properties": {
              "addressPrefix": "[cidrSubnet(parameters('hubAddressPrefix'), 26, 0)]"
            }
          },
          {
            "name": "GatewaySubnet",
            "properties": {
              "addressPrefix": "[cidrSubnet(parameters('hubAddressPrefix'), 27, 2)]"
            }
          },
          {
            "name": "ManagementSubnet",
            "properties": {
              "addressPrefix": "[cidrSubnet(parameters('hubAddressPrefix'), 24, 1)]",
              "networkSecurityGroup": {
                "id": "[resourceId('Microsoft.Network/networkSecurityGroups', variables('hubMgmtNsgName'))]"
              }
            }
          }
        ]
      }
    },
    {
      "condition": "[parameters('deployFirewall')]",
      "type": "Microsoft.Network/routeTables",
      "apiVersion": "2023-05-01",
      "name": "[variables('spoke1RouteTableName')]",
      "location": "[parameters('location')]",
      "tags": "[parameters('tags')]",
      "dependsOn": [
        "[resourceId('Microsoft.Network/azureFirewalls', variables('firewallName'))]"
      ],
      "properties": {
        "routes": [
          {
            "name": "default-via-firewall",
            "properties": {
              "addressPrefix": "0.0.0.0/0",
              "nextHopType": "VirtualAppliance",
              "nextHopIpAddress": "[if(parameters('deployFirewall'), reference(resourceId('Microsoft.Network/azureFirewalls', variables('firewallName'))).ipConfigurations[0].properties.privateIPAddress, '')]"
            }
          }
        ]
      }
    },
    {
      "condition": "[parameters('deployFirewall')]",
      "type": "Microsoft.Network/routeTables",
      "apiVersion": "2023-05-01",
      "name": "[variables('spoke2RouteTableName')]",
      "location": "[parameters('location')]",
      "tags": "[parameters('tags')]",
      "dependsOn": [
        "[resourceId('Microsoft.Network/azureFirewalls', variables('firewallName'))]"
      ],
      "properties": {
        "routes": [
          {
            "name": "default-via-firewall",
            "properties": {
              "addressPrefix": "0.0.0.0/0",
              "nextHopType": "VirtualAppliance",
              "nextHopIpAddress": "[if(parameters('deployFirewall'), reference(resourceId('Microsoft.Network/azureFirewalls', variables('firewallName'))).ipConfigurations[0].properties.privateIPAddress, '')]"
            }
          }
        ]
      }
    },
    {
      "type": "Microsoft.Network/virtualNetworks",
      "apiVersion": "2023-05-01",
      "name": "[variables('spoke1VnetName')]",
      "location": "[parameters('location')]",
