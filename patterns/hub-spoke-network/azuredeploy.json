      "dependsOn": [
        "[resourceId('Microsoft.Network/networkSecurityGroups', variables('spoke1NsgName'))]",
        "[resourceId('Microsoft.Network/routeTables', variables('spoke1RouteTableName'))]"
      ],
      "properties": {
        "addressSpace": {
          "addressPrefixes": [
            "[parameters('spoke1AddressPrefix')]"
          ]
        },
        "subnets": [
          {
            "name": "default",
            "properties": {
              "addressPrefix": "[cidrSubnet(parameters('spoke1AddressPrefix'), 24, 0)]",
              "networkSecurityGroup": {
                "id": "[resourceId('Microsoft.Network/networkSecurityGroups', variables('spoke1NsgName'))]"
              },
              "routeTable": "[if(parameters('deployFirewall'), json(concat('{\"id\": \"', resourceId('Microsoft.Network/routeTables', variables('spoke1RouteTableName')), '\"}')), null())]"
            }
          }
        ]
      }
    },
    {
      "type": "Microsoft.Network/virtualNetworks",
      "apiVersion": "2023-05-01",
      "name": "[variables('spoke2VnetName')]",
      "location": "[parameters('location')]",
      "tags": "[parameters('tags')]",
      "dependsOn": [
        "[resourceId('Microsoft.Network/networkSecurityGroups', variables('spoke2NsgName'))]",
        "[resourceId('Microsoft.Network/routeTables', variables('spoke2RouteTableName'))]"
      ],
      "properties": {
        "addressSpace": {
          "addressPrefixes": [
            "[parameters('spoke2AddressPrefix')]"
          ]
        },
        "subnets": [
          {
            "name": "default",
            "properties": {
              "addressPrefix": "[cidrSubnet(parameters('spoke2AddressPrefix'), 24, 0)]",
              "networkSecurityGroup": {
                "id": "[resourceId('Microsoft.Network/networkSecurityGroups', variables('spoke2NsgName'))]"
              },
              "routeTable": "[if(parameters('deployFirewall'), json(concat('{\"id\": \"', resourceId('Microsoft.Network/routeTables', variables('spoke2RouteTableName')), '\"}')), null())]"
            }
          }
        ]
      }
    },
    {
      "condition": "[parameters('deployFirewall')]",
      "type": "Microsoft.Network/azureFirewalls",
      "apiVersion": "2023-05-01",
      "name": "[variables('firewallName')]",
      "location": "[parameters('location')]",
      "tags": "[parameters('tags')]",
      "dependsOn": [
        "[resourceId('Microsoft.Network/publicIPAddresses', variables('firewallPublicIpName'))]",
        "[resourceId('Microsoft.Network/virtualNetworks', variables('hubVnetName'))]"
      ],
      "properties": {
        "sku": {
          "name": "AZFW_VNet",
          "tier": "Standard"
        },
        "ipConfigurations": [
          {
            "name": "firewallConfig",
            "properties": {
              "subnet": {
                "id": "[concat(resourceId('Microsoft.Network/virtualNetworks', variables('hubVnetName')), '/subnets/AzureFirewallSubnet')]"
              },
              "publicIPAddress": {
                "id": "[resourceId('Microsoft.Network/publicIPAddresses', variables('firewallPublicIpName'))]"
              }
            }
          }
        ],
        "networkRuleCollections": [
          {
            "name": "spoke-to-spoke",
            "properties": {
              "priority": 100,
              "action": {
                "type": "Allow"
              },
              "rules": [
                {
                  "name": "allow-spoke-traffic",
                  "protocols": [
                    "Any"
                  ],
                  "sourceAddresses": [
                    "[parameters('spoke1AddressPrefix')]",
                    "[parameters('spoke2AddressPrefix')]"
                  ],
                  "destinationAddresses": [
                    "[parameters('spoke1AddressPrefix')]",
                    "[parameters('spoke2AddressPrefix')]"
                  ],
                  "destinationPorts": [
                    "*"
                  ]
                }
              ]
            }
          }
        ]
      }
    },
    {
      "condition": "[parameters('deployVpnGateway')]",
      "type": "Microsoft.Network/virtualNetworkGateways",
      "apiVersion": "2023-05-01",
      "name": "[variables('vpnGatewayName')]",
      "location": "[parameters('location')]",
      "tags": "[parameters('tags')]",
      "dependsOn": [
        "[resourceId('Microsoft.Network/publicIPAddresses', variables('vpnGatewayPublicIpName'))]",
        "[resourceId('Microsoft.Network/virtualNetworks', variables('hubVnetName'))]"
