      "type": "string",
      "defaultValue": "demo",
      "metadata": {
        "description": "Prefix for resource naming"
      }
    },
    "tags": {
      "type": "object",
      "defaultValue": {
        "owner": "pattern-demo",
        "workload": "azure-monitor-baseline",
        "environment": "demo",
        "ttlHours": "24"
      },
      "metadata": {
        "description": "Resource tags"
      }
    },
    "retentionDays": {
      "type": "int",
      "defaultValue": 30,
      "metadata": {
        "description": "Log Analytics retention in days"
      }
    },
    "alertEmail": {
      "type": "string",
      "defaultValue": "alerts@example.com",
      "metadata": {
        "description": "Alert notification email address"
      }
    },
    "dailyQuotaGb": {
      "type": "int",
      "defaultValue": 1,
      "metadata": {
        "description": "Daily data ingestion cap in GB"
      }
    },
    "deploymentTime": {
      "type": "string",
      "defaultValue": "[utcNow('u')]",
      "metadata": {
        "description": "Deployment timestamp"
      }
    }
  },
  "variables": {
    "resourceSuffix": "[format('{0}-{1}', parameters('prefix'), uniqueString(resourceGroup().id))]",
    "commonTags": "[union(parameters('tags'), createObject('deployedAt', parameters('deploymentTime'), 'pattern', 'azure-monitor-baseline'))]",
    "logAnalyticsName": "[format('log-{0}', variables('resourceSuffix'))]",
    "appInsightsName": "[format('appi-{0}', variables('resourceSuffix'))]",
    "actionGroupName": "[format('ag-{0}', variables('resourceSuffix'))]",
    "alertRuleName": "[format('alert-{0}', variables('resourceSuffix'))]"
  },
  "resources": [
    {
      "type": "Microsoft.OperationalInsights/workspaces",
      "apiVersion": "2022-10-01",
      "name": "[variables('logAnalyticsName')]",
      "location": "[parameters('location')]",
      "tags": "[variables('commonTags')]",
      "properties": {
        "sku": {
          "name": "PerGB2018"
        },
        "retentionInDays": "[parameters('retentionDays')]",
        "workspaceCapping": {
          "dailyQuotaGb": "[parameters('dailyQuotaGb')]"
