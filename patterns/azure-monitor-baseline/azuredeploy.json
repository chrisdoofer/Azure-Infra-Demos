          "id": "[resourceId('Microsoft.OperationalInsights/workspaces', variables('logAnalyticsName'))]"
        },
        {
          "type": "Microsoft.Insights/components",
          "name": "[variables('appInsightsName')]",
          "id": "[resourceId('Microsoft.Insights/components', variables('appInsightsName'))]"
        },
        {
          "type": "Microsoft.Insights/actionGroups",
          "name": "[variables('actionGroupName')]",
          "id": "[resourceId('Microsoft.Insights/actionGroups', variables('actionGroupName'))]"
        }
      ]
    },
    "deploymentTimestamp": {
      "type": "string",
      "metadata": {
        "description": "Deployment timestamp"
      },
      "value": "[parameters('deploymentTime')]"
    }
  }
