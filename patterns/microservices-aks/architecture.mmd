    end
    
    User[External Client] -->|kubectl/HTTPS| AKS
    AKS --> POD1
    AKS --> POD2
    AKS --> POD3
    
    POD1 -.->|Pull Images<br/>Kubelet Identity| ACR
    POD2 -.->|Pull Images<br/>Kubelet Identity| ACR
    POD3 -.->|Pull Images<br/>Kubelet Identity| ACR
    
    POD1 -.->|Get Secrets<br/>CSI Driver| KV
    POD2 -.->|Get Secrets<br/>CSI Driver| KV
    
    AKS -.->|OMS Agent<br/>Metrics & Logs| LOG
    AKS -.->|Telemetry| APPI
    LOG -->|Workspace| APPI
    
    AKS -.->|Secrets User RBAC| KV
    
    classDef vnet fill:#E8F4FD,stroke:#0078D4,stroke-width:2px,color:#000
    classDef aks fill:#0078D4,stroke:#000,stroke-width:2px,color:#fff
    classDef pods fill:#50E6FF,stroke:#000,stroke-width:2px,color:#000
    classDef support fill:#00BCF2,stroke:#000,stroke-width:2px,color:#000
    classDef user fill:#107C10,stroke:#000,stroke-width:2px,color:#fff
    classDef monitor fill:#FFB900,stroke:#000,stroke-width:2px,color:#000
    
    class AKS aks
    class POD1,POD2,POD3 pods
