graph TB
    subgraph "Azure Virtual Network (10.1.0.0/16)"
        subgraph "AKS Subnet (10.1.0.0/20)"
            AKS[AKS Cluster<br/>Kubernetes 1.29<br/>System Node Pool<br/>2x Standard_B2s]
            POD1[Pod: Service A]
            POD2[Pod: Service B]
            POD3[Pod: Service C]
        end
        
        subgraph "Services Subnet (10.1.16.0/24)"
            SVC[Additional Services<br/>Private Endpoints]
        end
    end
    
    subgraph "Supporting Services"
        ACR[Container Registry<br/>Basic SKU<br/>ACR Pull RBAC]
        KV[Key Vault<br/>RBAC Auth<br/>Soft Delete 90d<br/>Purge Protection]
        LOG[Log Analytics<br/>30-day Retention<br/>PerGB2018]
